{
  /**
   * Typecheck config for executable scripts (run via tsx). Kept separate from the
   * browser app tsconfig: scripts are a Node environment (node: builtins, process,
   * Buffer), not the DOM — mixing the two would either miss Node types or strip the
   * ambient @types/react JSX namespace from the app. See docs/doctrine/tooling-doctrine.md.
   */
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true
  },
  "include": ["scripts"]
}
