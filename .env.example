# Copy to .env.local (gitignored) and fill in.
#
# Convex deployment URL, consumed by the browser client (ConvexProvider.tsx).
# Printed by `npx convex dev` on first run, e.g. https://your-deployment.convex.cloud
VITE_CONVEX_URL=

# Convex deployment identifier used by the Convex CLI (`convex dev` / `convex deploy`).
# Written automatically by `npx convex dev`; usually you do not set this by hand.
CONVEX_DEPLOYMENT=
