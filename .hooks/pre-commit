#!/bin/sh
# Activate once per clone:  git config core.hooksPath .hooks
# Bypass in an emergency:   git commit --no-verify   (CI still enforces both gates)

# Gate 1 (mechanical): doctrine manifest coverage · path · pointer.
# Zero-dep by design — runs in a bare checkout, before `pnpm install`.
bash docs/scripts/doctrine-lint.sh || exit 1

# Gate 2 (convenience): auto-format staged files so formatting never reaches CI.
# Optional-by-design — skipped when node_modules is absent, preserving the
# zero-dep guarantee of Gate 1 above. Prettier honors .prettierignore.
if [ -x node_modules/.bin/prettier ]; then
  staged=$(git diff --cached --name-only --diff-filter=ACMR)
  if [ -n "$staged" ]; then
    printf '%s\n' "$staged" | xargs node_modules/.bin/prettier --write --ignore-unknown --log-level warn
    printf '%s\n' "$staged" | xargs git add
  fi
fi
