{
  "name": "@soulbound/babel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n vite,convex \"vite\" \"convex dev\"",
    "build": "vite build",
    "compile": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "script:verify-boundaries": "tsx scripts/verify-boundaries.ts",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "ci:local": "pnpm compile && pnpm lint && pnpm format:check && pnpm script:verify-boundaries && pnpm test:unit:ci && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.8.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "convex": "^1.42.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  }
}
